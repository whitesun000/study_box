# 仮想環境
venv/
.venv

# Pythonのキャッシュ
__pycache__/
*.pyc

# ログファイル（作成中のツールの出力結果）
*.log

# エディタ設定
.vscode/
.idea/
*.swp
*.swo

# logsフォルダの中身（.logファイル）は無視する
logs/*.log

# --- セキュリティ・共通設定 ---
# 環境変数ファイル（秘密鍵やポート設定が含まれるためNG）
.env

# データベースファイル（ユーザー情報が含まれるため）
*.sqlite3
*.db

# OS固有のキャッシュ
.DS_Store
Thumbs.db

# その他
Q&A.md